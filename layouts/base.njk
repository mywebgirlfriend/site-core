{#
========================================================

Arquivo:
layouts/base.njk

Objetivo:
Layout base de todo o projeto.

Este arquivo contém apenas a estrutura comum
de todas as páginas.

Layouts especializados (como blog.njk)
devem herdar deste arquivo.

A documentação correspondente estará em:
docs/03-layout-base.md

========================================================
#}

<!DOCTYPE html>
<html lang="pt-BR">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>
        {% block title %}
            Meu Site
        {% endblock %}
    </title>

    <link
        rel="stylesheet"
        href="/assets/css/style.css">

    {% block extraCss %}
    {% endblock %}

</head>
<body>

<div class="layout">

    <aside class="sidebar">

        <nav>

            <ul>

                <li>
                    <a href="/">
                        Home
                    </a>
                </li>

                <li>
                    <a href="/blog/">
                        Blog
                    </a>
                </li>

                <li>
                    <a href="/pics/">
                        Pics
                    </a>
                </li>

                <li>
                    <a href="/links/">
                        Links
                    </a>
                </li>

            </ul>

        </nav>

    </aside>

    <main class="content">

        {% block body %}

            {{ content | safe }}

        {% endblock %}

    </main>

</div>

</body>

</html>
